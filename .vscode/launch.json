{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Debug main.py (with mitmproxy)",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}\\main.py",
      "console": "integratedTerminal",
      "cwd": "${workspaceFolder}",
      "preLaunchTask": "mitmproxy:start",
      "postDebugTask": "mitmproxy:stop"
    }
  ]
}
